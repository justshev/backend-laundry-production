{
  "name": "laundrypro-backend",
  "version": "1.0.0",
  "description": "Backend API for LaundryPro using Express, Prisma, and Supabase Postgres",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node scripts/prisma-direct.cjs migrate dev",
    "prisma:deploy": "node scripts/prisma-direct.cjs migrate deploy",
    "prisma:studio": "node scripts/prisma-direct.cjs studio",
    "prisma:seed": "node scripts/prisma-direct.cjs db seed"
  },
  "keywords": [
    "express",
    "prisma",
    "supabase",
    "postgresql",
    "laundry",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  }
}
