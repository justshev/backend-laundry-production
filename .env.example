NODE_ENV=development
PORT=4000
APP_NAME=LaundryPro API
CORS_ORIGIN=http://localhost:8080

# Supabase Prisma runtime URL (Transaction mode / port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Direct connection for Prisma migrate/introspect (Session mode / port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_DEBUG_PREVIEW=true

FONNTE_BASE_URL=https://api.fonnte.com
FONNTE_TOKEN=
FONNTE_COUNTRY_CODE=62
FONNTE_WEBHOOK_SECRET=dev-webhook-secret
